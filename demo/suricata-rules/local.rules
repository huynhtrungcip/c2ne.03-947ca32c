# =====================================================================
# CUSTOM SURICATA RULES — AI-SOC Demo
# Tuned for ML model trained on CICIDS-2017 (11 classes)
# Coverage: Bot, DDoS, DoS (GoldenEye/Hulk/Slowloris/Slowhttptest),
#           PortScan, FTP-Patator, SSH-Patator, Web Attack, BENIGN baseline
#
# Network layout (from topology):
#   ATTACKER  : 192.168.168.0/24  (Kali = 192.168.168.23)
#   FIREWALL  : 192.168.168.254 (WAN) / 10.10.10.254 / 172.16.16.254
#   DMZ       : 172.16.16.0/24   (WEB=.30, NIDS=.20)
#   SOC       : 10.10.10.0/24    (AI=.20)
#
# SID range  : 9000000 – 9000099  (custom, no collision with ET Open)
# =====================================================================

# ---------- 1. PortScan (nmap / masscan SYN scan) ----------
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC PortScan SYN Scan Detected"; \
    flags:S; threshold:type both, track by_src, count 30, seconds 10; \
    classtype:attempted-recon; sid:9000001; rev:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC PortScan FIN/NULL/XMAS Stealth Scan"; \
    flags:FPU,12; threshold:type both, track by_src, count 10, seconds 10; \
    classtype:attempted-recon; sid:9000002; rev:1;)

# ---------- 2. DDoS (hping3 SYN flood, high pps) ----------
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC DDoS SYN Flood (hping3 pattern)"; \
    flags:S; threshold:type both, track by_dst, count 200, seconds 5; \
    classtype:attempted-dos; sid:9000010; rev:1;)

alert udp $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC DDoS UDP Flood"; \
    threshold:type both, track by_dst, count 300, seconds 5; \
    classtype:attempted-dos; sid:9000011; rev:1;)

# ---------- 3. DoS Hulk (HTTP GET flood, randomized URI/UA) ----------
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC DoS Hulk HTTP Flood"; \
    flow:to_server,established; http.method; content:"GET"; \
    threshold:type both, track by_src, count 80, seconds 10; \
    classtype:attempted-dos; sid:9000020; rev:1;)

# ---------- 4. DoS GoldenEye (Keep-Alive + Cache-Control no-cache flood) ----------
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC DoS GoldenEye Keep-Alive Abuse"; \
    flow:to_server,established; http.header; content:"Cache-Control|3a 20|no-cache"; nocase; \
    threshold:type both, track by_src, count 40, seconds 10; \
    classtype:attempted-dos; sid:9000021; rev:1;)

# ---------- 5. DoS Slowloris (incomplete headers, partial requests) ----------
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC DoS Slowloris Partial HTTP Headers"; \
    flow:to_server,established; http.header_names; content:"X-a|3a|"; nocase; \
    threshold:type both, track by_src, count 15, seconds 30; \
    classtype:attempted-dos; sid:9000022; rev:1;)

# ---------- 6. DoS Slowhttptest (slow POST, long-running) ----------
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC DoS Slowhttptest Slow POST"; \
    flow:to_server,established; http.method; content:"POST"; \
    http.header; content:"Content-Length|3a 20|"; \
    threshold:type both, track by_src, count 20, seconds 60; \
    classtype:attempted-dos; sid:9000023; rev:1;)

# ---------- 7. FTP-Patator (FTP brute force) ----------
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"AI-SOC FTP-Patator Brute Force"; \
    flow:to_server,established; content:"USER "; depth:5; \
    threshold:type both, track by_src, count 10, seconds 30; \
    classtype:attempted-user; sid:9000030; rev:1;)

alert tcp $HOME_NET 21 -> $EXTERNAL_NET any (msg:"AI-SOC FTP Login Failed (patator response)"; \
    flow:from_server,established; content:"530 "; depth:4; \
    threshold:type both, track by_dst, count 5, seconds 30; \
    classtype:unsuccessful-user; sid:9000031; rev:1;)

# ---------- 8. SSH-Patator (SSH brute force / hydra) ----------
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"AI-SOC SSH-Patator Brute Force"; \
    flow:to_server,established; \
    threshold:type both, track by_src, count 8, seconds 30; \
    classtype:attempted-user; sid:9000040; rev:1;)

# ---------- 9. Web Attack: SQL Injection ----------
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC Web Attack SQL Injection (UNION SELECT)"; \
    flow:to_server,established; http.uri; \
    pcre:"/(union(\s|\+|%20)+select|or(\s|\+|%20)+1=1|sleep\(\d+\)|benchmark\()/i"; \
    classtype:web-application-attack; sid:9000050; rev:1;)

# ---------- 10. Web Attack: XSS ----------
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC Web Attack XSS Reflected"; \
    flow:to_server,established; http.uri; \
    pcre:"/(<script|javascript:|onerror=|onload=|alert\()/i"; \
    classtype:web-application-attack; sid:9000051; rev:1;)

# ---------- 11. Web Attack: Path Traversal / LFI ----------
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"AI-SOC Web Attack Path Traversal / LFI"; \
    flow:to_server,established; http.uri; \
    pcre:"/(\.\.\/|\.\.\\|%2e%2e%2f|\/etc\/passwd|\/proc\/self)/i"; \
    classtype:web-application-attack; sid:9000052; rev:1;)

# ---------- 12. Bot / C2 Beacon (regular interval HTTP to suspicious UA) ----------
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"AI-SOC Bot C2 Beacon Suspicious User-Agent"; \
    flow:to_server,established; http.user_agent; \
    pcre:"/^(curl|wget|python-requests|Go-http-client|Mozilla\/4\.0 \(compatible; MSIE)/i"; \
    threshold:type both, track by_src, count 5, seconds 60; \
    classtype:trojan-activity; sid:9000060; rev:1;)

alert dns $HOME_NET any -> any 53 (msg:"AI-SOC Bot DNS Tunneling Long Subdomain"; \
    dns.query; pcre:"/^[a-f0-9]{40,}\./i"; \
    classtype:trojan-activity; sid:9000061; rev:1;)

# =====================================================================
# Notes for demo presentation:
# - These rules trigger Suricata alerts → forwarded to AI engine.
# - AI engine cross-checks against Zeek conn.log (community_id) before
#   issuing final verdict on the SOC dashboard.
# - Standalone Zeek flows (no Suricata match) are also analyzed by the
#   ML model (CICIDS-trained) via /analyze/zeek every 30s.
# - BENIGN traffic is NOT alerted — it appears only via Zeek+ML pipeline.
# =====================================================================
