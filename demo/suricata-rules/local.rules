# =====================================================================
# AI-SOC DEMO — local.rules
# Optimised for the C1NE.03 dashboard demo (2026-04-25).
# Maps directly to the 10 ML training classes the model recognises:
#   PortScan, SSH-Patator, FTP-Patator, Web Attack,
#   DoS Hulk, DoS GoldenEye, DoS slowloris, DoS Slowhttptest, Bot, BENIGN
#
# DDoS class is intentionally excluded — historical baseline already
# contains one DDoS incident (23/04 mock data) for chart variety.
#
# Thresholds are tuned for a SINGLE attacker IP (192.168.168.23) so the
# dashboard shows a clear, paced storyline — not a flood.
#
# Activate by appending to suricata.yaml `rule-files:`
#   - local.rules
# =====================================================================

# ---------- 1. PortScan ----------
alert tcp any any -> $HOME_NET any (msg:"DEMO PortScan SYN sweep"; \
   flags:S; \
   threshold:type both, track by_src, count 30, seconds 60; \
   classtype:attempted-recon; sid:9000001; rev:1;)

# ---------- 2. SSH-Patator (brute force) ----------
alert tcp any any -> $HOME_NET 22 (msg:"DEMO SSH-Patator brute force"; \
   flow:to_server,established; \
   threshold:type both, track by_src, count 6, seconds 60; \
   classtype:attempted-user; sid:9000002; rev:1;)

# ---------- 3. FTP-Patator (brute force) ----------
alert tcp any any -> $HOME_NET 21 (msg:"DEMO FTP-Patator brute force"; \
   flow:to_server,established; \
   content:"USER"; nocase; \
   threshold:type both, track by_src, count 5, seconds 60; \
   classtype:attempted-user; sid:9000003; rev:1;)

# ---------- 4. Web Attack — SQL Injection ----------
alert http any any -> $HOME_NET any (msg:"DEMO Web Attack SQL Injection"; \
   flow:to_server,established; \
   pcre:"/(\bunion\b.+\bselect\b|\bor\b\s+1=1|--\s|';\s*drop\b)/i"; \
   classtype:web-application-attack; sid:9000004; rev:1;)

# ---------- 5. Web Attack — XSS ----------
alert http any any -> $HOME_NET any (msg:"DEMO Web Attack XSS"; \
   flow:to_server,established; \
   pcre:"/<script.*?>|onerror\s*=|javascript:/i"; \
   classtype:web-application-attack; sid:9000005; rev:1;)

# ---------- 6. Web Attack — Path Traversal / LFI ----------
alert http any any -> $HOME_NET any (msg:"DEMO Web Attack Path Traversal"; \
   flow:to_server,established; \
   content:"../"; depth:200; \
   classtype:web-application-attack; sid:9000006; rev:1;)

# ---------- 7. DoS Hulk (cache-buster HTTP flood) ----------
alert http any any -> $HOME_NET any (msg:"DEMO DoS Hulk HTTP Flood"; \
   flow:to_server,established; \
   content:"Cache-Control|3a 20|no-cache"; nocase; \
   threshold:type both, track by_src, count 80, seconds 30; \
   classtype:attempted-dos; sid:9000007; rev:1;)

# ---------- 8. DoS GoldenEye ----------
alert http any any -> $HOME_NET any (msg:"DEMO DoS GoldenEye"; \
   flow:to_server,established; \
   content:"User-Agent|3a 20|"; \
   pcre:"/User-Agent:\s*Mozilla\/[45]\.[0-9].*?KHTML/i"; \
   threshold:type both, track by_src, count 60, seconds 30; \
   classtype:attempted-dos; sid:9000008; rev:1;)

# ---------- 9. DoS slowloris (slow headers) ----------
alert tcp any any -> $HOME_NET 80 (msg:"DEMO DoS slowloris partial header"; \
   flow:to_server,established; \
   content:"X-a|3a 20|"; \
   threshold:type both, track by_src, count 20, seconds 60; \
   classtype:attempted-dos; sid:9000009; rev:1;)

# ---------- 10. DoS Slowhttptest (slow POST) ----------
alert tcp any any -> $HOME_NET 80 (msg:"DEMO DoS Slowhttptest slow POST"; \
   flow:to_server,established; \
   content:"POST"; depth:4; \
   content:"Content-Length|3a 20|8192"; \
   threshold:type both, track by_src, count 15, seconds 60; \
   classtype:attempted-dos; sid:9000010; rev:1;)

# ---------- 11. Bot / C2 Beacon ----------
alert http any any -> $EXTERNAL_NET any (msg:"DEMO Bot C2 Beacon (python-requests UA)"; \
   flow:to_server,established; \
   content:"User-Agent|3a 20|python-requests"; nocase; \
   threshold:type both, track by_src, count 4, seconds 120; \
   classtype:trojan-activity; sid:9000011; rev:1;)

# ---------------------------------------------------------------------
# Reference rules — NOT used during live demo (.23 single-IP scenario).
# Kept here so the historical DDoS sample on 23/04 (160 spoofed-src
# SYN floods to 172.16.16.30:80) maps to a real signature if the
# operator chooses to replay it from a packet capture.
# ---------------------------------------------------------------------

# ---------- REF-A. DDoS — distributed SYN flood (audit only) ----------
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (msg:"DEMO DDoS distributed SYN flood"; \
   flags:S; \
   threshold:type both, track by_dst, count 100, seconds 30; \
   classtype:attempted-dos; sid:9000012; rev:1;)
