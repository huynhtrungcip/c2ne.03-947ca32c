# ============================================================
# SOC Dashboard - Environment Configuration
# Copy this file to .env and fill in your values
# Author: C1NE.03 Team - Cybersecurity K28 - Duy Tan University
# ============================================================

# ==================== Frontend Configuration ====================
# URL của Backend API (thay YOUR_SERVER_IP bằng IP server của bạn)
VITE_API_URL=http://YOUR_SERVER_IP:3001
VITE_WS_URL=ws://YOUR_SERVER_IP:3002
VITE_AI_URL=http://YOUR_SERVER_IP:8000

# Port cho frontend (mặc định 8080)
FRONTEND_PORT=8080

# ==================== MegaLLM Configuration ====================
# Lấy API key tại: https://megallm.io
MEGALLM_API_KEY=your-megallm-api-key-here
MEGALLM_BASE_URL=https://ai.megallm.io/v1
MEGALLM_DEFAULT_MODEL=deepseek-r1-distill-llama-70b

# ==================== pfSense Configuration ====================
# Để tích hợp auto-block IP độc hại
PFSENSE_HOST=10.10.10.254
PFSENSE_PORT=8080
PFSENSE_SCHEME=http
PFSENSE_API_KEY=your-pfsense-api-key-here
PFSENSE_ALIAS=AI_Blocked_IP

# ==================== Whitelist IPs ====================
# Danh sách IP không bao giờ bị block (phân cách bằng dấu phẩy)
WHITELIST_IPS=10.10.10.20,10.10.10.254,172.16.16.20,172.16.16.254

# ==================== Node.js Backend ====================
PORT=3001
WS_PORT=3002
NODE_ENV=production

# ==================== Telegram Bot (Optional) ====================
# Để nhận thông báo qua Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ==================== Timezone ====================
TZ=Asia/Ho_Chi_Minh
