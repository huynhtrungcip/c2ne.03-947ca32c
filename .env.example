# ===== SOC Dashboard Configuration =====
# Copy this file to .env and fill in your values

# Backend API URLs (for frontend)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3002
VITE_AI_URL=http://localhost:8000

# ===== MegaLLM Configuration =====
MEGALLM_API_KEY=your-megallm-api-key
MEGALLM_BASE_URL=https://ai.megallm.io/v1
MEGALLM_DEFAULT_MODEL=deepseek-r1-distill-llama-70b

# ===== pfSense Configuration =====
PFSENSE_HOST=10.10.10.254
PFSENSE_PORT=8080
PFSENSE_API_KEY=your-pfsense-api-key
PFSENSE_ALIAS=AI_Blocked_IP

# ===== Whitelist IPs (comma-separated) =====
WHITELIST_IPS=10.10.10.20,10.10.10.254,172.16.16.20,172.16.16.254

# ===== Node.js Backend =====
PORT=3001
WS_PORT=3002
AI_ENGINE_URL=http://ai-engine:8000

# ===== NIDS Log Shipper Target =====
# AI Engine listens on /ingest for logs from ai_log_shipper.py
# Shipper sends to: http://10.10.10.20:8000/ingest
